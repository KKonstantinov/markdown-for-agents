{
    "name": "@markdown-for-agents/express",
    "version": "1.3.4",
    "description": "Express middleware — serve Markdown to AI agents via content negotiation",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=22"
    },
    "files": [
        "dist",
        "LICENSE"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run test/integration",
        "typecheck": "tsgo --noEmit"
    },
    "dependencies": {
        "markdown-for-agents": "workspace:*"
    },
    "peerDependencies": {
        "express": ">=4.0.0"
    },
    "devDependencies": {
        "express": "^5.2.1",
        "@types/express": "^5.0.6"
    },
    "keywords": [
        "html",
        "markdown",
        "converter",
        "ai",
        "agents",
        "llm",
        "tokens",
        "express",
        "express-middleware",
        "middleware",
        "content-negotiation"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/KKonstantinov/markdown-for-agents.git",
        "directory": "packages/middleware/express"
    },
    "homepage": "https://github.com/KKonstantinov/markdown-for-agents/tree/main/packages/middleware/express#readme",
    "bugs": {
        "url": "https://github.com/KKonstantinov/markdown-for-agents/issues"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "license": "MIT"
}
