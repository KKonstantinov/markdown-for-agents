{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true,
        "paths": {
            "markdown-for-agents": ["./packages/core/src/index.ts"],
            "markdown-for-agents/tokens": ["./packages/core/src/tokens/index.ts"],
            "markdown-for-agents/extract": ["./packages/core/src/extract/index.ts"],
            "@markdown-for-agents/express": ["./packages/middleware/express/src/index.ts"],
            "@markdown-for-agents/fastify": ["./packages/middleware/fastify/src/index.ts"],
            "@markdown-for-agents/hono": ["./packages/middleware/hono/src/index.ts"],
            "@markdown-for-agents/nextjs": ["./packages/middleware/nextjs/src/index.ts"],
            "@markdown-for-agents/web": ["./packages/middleware/web/src/index.ts"]
        }
    },
    "include": [
        "packages/core/src",
        "packages/core/test",
        "packages/core/*.config.ts",
        "packages/audit/src",
        "packages/audit/test",
        "packages/audit/*.config.ts",
        "packages/middleware/*/src",
        "packages/middleware/*/test",
        "packages/middleware/*/*.config.ts",
        "packages/middleware/*.ts",
        "examples/*/src",
        "examples/*/test",
        "examples/*/*.config.ts",
        "*.config.ts",
        "packages/docs/src/**/*.ts",
        "packages/docs/src/**/*.tsx"
    ],
    "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
