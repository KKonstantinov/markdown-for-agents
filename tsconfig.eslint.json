{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "rootDir": ".",
        "noEmit": true
    },
    "include": [
        "packages/core/src",
        "packages/core/test",
        "packages/core/*.config.ts",
        "packages/audit/src",
        "packages/audit/test",
        "packages/audit/*.config.ts",
        "packages/middleware/*/src",
        "packages/middleware/*/test",
        "packages/middleware/*/*.config.ts",
        "packages/middleware/*.ts",
        "examples/*/src",
        "examples/*/test",
        "examples/*/*.config.ts",
        "*.config.ts",
        "docs/.vitepress/**/*.ts"
    ],
    "exclude": ["node_modules", "**/dist", "**/node_modules"]
}
